VITE_VERSION=1.0.0
VITE_PRODUCTION=false
VITE_CREDENTIALS_KEY=your-credentials-key
VITE_PATH_PARAMS_KEY=your-path-params-key
VITE_OAUTH_STORAGE_KEY=your-oauth-storage-key
VITE_MOCK_AUTH=false
VITE_MOCK_MENU=false

# En desarrollo/QA: ruta relativa (el proxy de Vite la intercepta)
# En producción: URL completa del backend
VITE_BASE_URL=/your-api-base-path

# Solo en desarrollo/QA — NO añadir prefijo VITE_ para no exponer la URL en el bundle
API_TARGET=http://your-backend-server:port
